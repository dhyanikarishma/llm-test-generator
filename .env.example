# Copy this file to ".env" and paste your real key(s) after the "=" sign.
# You only need ONE provider to use the app. Groq is free and recommended.
# NEVER commit the real .env file (it is already in .gitignore).

# Groq (free)        -> https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (free tier, optional) -> https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional: set to 1 to allow running AI-generated tests in a local sandbox.
# Leave unset/0 in any public deployment (it executes generated code).
# ENABLE_SANDBOX_RUN=0
